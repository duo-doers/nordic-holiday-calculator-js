{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest"]
  },
  "include": ["lib/**/*", "index.ts", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
